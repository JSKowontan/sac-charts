{
  "id": "com.autodeck.custom.bar.chart",
  "name": "Bar Chart",
  "description": "A bar chart highlighting current and prior year.",
  "eula": "autodeck.com",
  "vendor": "Autodeck",
  "license": "MIT",
  "newInstancePrefix": "AutodeckBarChart",
  "version": "1.0.0",
  "icon": "https://cdn.jsdelivr.net/gh/JSKowontan/sac-charts/Bar/Bar_Chart_1/barChartIcon.png",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "custom-bar-chart",
      "url": "https://cdn.jsdelivr.net/gh/JSKowontan/sac-charts@548323997f091bc7de2ad9c6ac42f3bf3ab3e626/Bar/Bar_Chart_1/webcomponent.js",
      "integrity": "sha256-KKZZRcLAdEIUByD0Ve7lMk/6QJu4LkFRuvSZrHfPwRo=",
      "ignoreIntegrity": false
    },
    {
      "kind": "builder",
      "tag": "custom-bar-chart-builder",
      "url": "https://cdn.jsdelivr.net/gh/JSKowontan/sac-charts@548323997f091bc7de2ad9c6ac42f3bf3ab3e626/Bar/Bar_Chart_1/webcomponent.js",
      "integrity": "sha256-KKZZRcLAdEIUByD0Ve7lMk/6QJu4LkFRuvSZrHfPwRo=",
      "ignoreIntegrity": false
    }
  ],
  "properties": {
    "showAxis": {
      "type": "boolean",
      "description": "Show/Hide Axis labels",
      "default": false
    },
    "showLegend": { 
        "type": "boolean", 
        "description": "Show/Hide legends for CY and LY",
        "default": true },
    "colorLY": {
      "type": "string",
      "description": "Color for LY bars",
      "default": "#e0e0e0"
    },
    "colorCY": {
      "type": "string",
      "description": "Color for CY bars",
      "default": "#6495ed"
    },
    "barWidth": {
      "type": "integer",
      "description": "Width of bars in pixels",
      "default": 30
    },
    "measureName": {
      "type": "string",
      "description": "Name of the measure to display in tooltip",
      "default": ""
    }
  },
  "methods": {
    "setChartData": {
      "description": "Sets the chart data JSON",
      "parameters": [
        {
          "name": "RecordsArray",
          "type": "Selection[]",
          "description": "JSON String like [{'year': '2025', 'period': 'JAN', 'indicator': 'LY', 'value': '100', 'currency': 'NGN'}]"
        }
      ]
    }
  },
  "events": {
    "onBarClick": {
      "description": "Triggered when a bar is clicked"
    }
  }
}
